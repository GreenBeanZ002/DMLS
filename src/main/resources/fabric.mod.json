{
  "schemaVersion": 1,
  "id": "dmls",
  "version": "${version}",
  "name": "Duper's Mod for Lazy Staff",
  "description": "A mod made for the LAZY staff of stoneworks",
  "authors": ["DuperKnight", "Siaffs"],
  "contact": {
    "issues": "https://github.com/DuperKnight/DMLS/issues",
    "sources": "https://github.com/DuperKnight/DMLS"
  },
  "license": "MIT",
  "icon": "assets/dmls/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.duperknight.client.DMLSClient"
    ],
    "modmenu": [
      "com.duperknight.client.gui.ModMenuIntegration"
    ]
  },
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  },
  "suggests": {
    "modmenu": "*"
  }
}
