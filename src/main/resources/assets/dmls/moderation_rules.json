{
  "schemaVersion": 2,
  "rules": [
    {
      "id": "spam",
      "labelKey": "dmls.moderation.automatic_rule.spam",
      "defaultEnabled": true,
      "channels": ["global", "local"],
      "match": "any",
      "requirements": [
        {
          "metric": "message_count",
          "groupBy": "similar_content",
          "minimum": 4,
          "windowMs": 5000,
          "similarityThreshold": 0.8,
          "fuzzyMinLength": 8
        },
        {
          "metric": "message_count",
          "groupBy": "sender",
          "minimum": 3,
          "windowMs": 2500
        }
      ]
    },
    {
      "id": "text_wall",
      "labelKey": "dmls.moderation.automatic_rule.text_wall",
      "defaultEnabled": true,
      "channels": ["global", "local"],
      "match": "all",
      "requirements": [
        {
          "metric": "rendered_lines",
          "minimum": 5
        }
      ]
    }
  ]
}
